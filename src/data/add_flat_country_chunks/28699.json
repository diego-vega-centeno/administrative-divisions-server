    "id": "17711940",
    "parent": "2624773",
    "text": "\u0411\u0430\u04ad\u0430\u0438\u0433\u04d9\u0430\u0440\u0430 \u0430\u049b\u044b\u04ad\u0430 \u0430\u0445\u0430\u0434\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17705275",
    "parent": "2624773",
    "text": "\u0411\u0447\u0430\u0440\u0430 \u0430\u049b\u044b\u04ad\u0430 \u0430\u0445\u0430\u0434\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17711942",
    "parent": "2624773",
    "text": "\u0413\u0430\u0433\u0438\u0434\u0430 \u0430\u049b\u044b\u04ad\u0430 \u0430\u0445\u0430\u0434\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17705274",
    "parent": "2624773",
    "text": "\u0414\u0438\u0445\u0430\u0437\u0443\u0440\u0433\u0430 \u0430\u049b\u044b\u04ad\u0430 \u0430\u0445\u0430\u0434\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17711689",
    "parent": "2624773",
    "text": "\u041c\u0430\u0440\u0447\u0445\u0430\u043f\u043e\u043d \u0430\u049b\u044b\u04ad\u0430 \u0430\u0445\u0430\u0434\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17550181",
    "parent": "2624773",
    "text": "\u041c\u0430\u0445\u04d9\u0438\u045f\u044c\u0440\u0430 \u0430\u049b\u044b\u04ad\u0430 \u0430\u0445\u0430\u0434\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17568075",
    "parent": "2624773",
    "text": "\u041f\u0440\u0438\u043c\u043e\u0440\u0441\u043a",
    "admin_level": "8"
  },
  {
    "id": "17560832",
    "parent": "2624773",
    "text": "\u0420\u044c\u0430\u043f \u0430\u049b\u044b\u04ad\u0430 \u0430\u0445\u0430\u0434\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17555979",
    "parent": "2624773",
    "text": "\u0421\u0435\u043b\u044c\u0441\u043a\u0430\u044f \u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u044f \u0410\u043b\u0430\u043a\u0443\u043c\u0445\u0430\u0440\u0430",
    "admin_level": "8"
  },
  {
    "id": "17585711",
    "parent": "2624773",
    "text": "\u0421\u0435\u043b\u044c\u0441\u043a\u0430\u044f \u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u044f \u0412\u0435\u0440\u0445\u043d\u0438\u0439 \u0411\u0430\u0440\u0433\u044f\u043f",
    "admin_level": "8"
  },
  {
    "id": "17569705",
    "parent": "2624773",
    "text": "\u0421\u0435\u043b\u044c\u0441\u043a\u0430\u044f \u0430\u0434\u043c\u0438\u043d\u0438\u0441\u0442\u0440\u0430\u0446\u0438\u044f \u041d\u0438\u0436\u043d\u0438\u0439 \u0411\u0430\u0440\u0433\u044f\u043f",
    "admin_level": "8"
  },
  {
